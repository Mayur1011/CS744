#include <stdio.h>
#include <unistd.h>

void create_processes(int level) {
    if (level == 1) return;
    create_processes(level - 1);
    pid_t left_child = fork();
    printf("This is my left child : %d\n", left_child);

    create_processes(level - 1);
    pid_t right_child = fork();
    printf("This is my right child : %d\n", right_child);
}

int main (void) {
    pid_t root_process_id = getpid();
    pid_t process_group_id = getpgrp();
    printf("HERE : %d\n", root_process_id);
    create_processes(2);
    sleep(10000);
}
